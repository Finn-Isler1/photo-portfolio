---
import BaseLayout from '../layouts/BaseLayout.astro';
import myselfPic from '../assets/images/myself-picture.jpg';
const pageTitle = 'About Page';
const base = import.meta.env.BASE_URL || '/';
---

<BaseLayout pageTitle={pageTitle}>
  <h2>About</h2>
  <hr />
  <div class="main-max-width container">
    <img src={myselfPic.src} alt="Finn Isler" />
    <div class="text-wrapper">
      <h3>Finn Isler</h3>
      <p>
        I am a photographer and videographer based in Charlotte/Raleigh, NC. I
        went to school at UNC Charlotte and graduated in May of 2026.
      </p>
      <p>
        During my time there, I learned to shoot and edit photo and video for a
        variety of different projects, including fashion, editorial,
        documentary, and music video.
      </p>
      <p>
        One thing to know about me that I am extremely open-minded and always
        interested.
      </p>
      <p>
        Please feel free to reach out regarding work inquiries or general
        questions!
      </p>
      <button id="contact-page" class="contact-page-button">Contact Me</button>
    </div>
  </div>
</BaseLayout>

<script>
  import { base } from 'astro:config/client';

  const contactButton = document.getElementById('contact-page');
  if (contactButton) {
    contactButton.addEventListener('click', () => {
      window.location.href = `${base}contact`;
    });
  }
</script>

<style>
  h2 {
    font-family: var(--serif);
    font-size: 2.5rem;
    font-weight: 200;
    margin-top: 2rem;
  }

  .container {
    display: flex;
    flex-direction: row;
    gap: 20px;
    margin-top: 4em;
    width: 100%;
    justify-content: center;
  }
  img {
    height: auto;
    max-width: 400px;
    width: 100%;
    display: flex;
  }

  .text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 2em 2em;
    align-items: center;
    max-width: 400px;
  }

  h3 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 200;
    margin-top: 2rem;
    text-align: center;
  }

  p {
    font-size: 1rem;
  }

  .contact-page-button {
    border: none;
    padding: 10px 20px;
    background-color: var(--secondary-text-color: rgb(87, 87, 87));
    font-weight: 400;
    font-size: 1rem;
    border-radius: 20px;
    margin-top: 2rem;
  }

  .contact-page-button:hover {
    cursor: pointer;
    background-color: var(--primary-text-color: rgb(33, 33, 33));
    color: var(--background-color: rgb(250, 250, 250));
    transition: 0.3s ease;
  }
</style>
