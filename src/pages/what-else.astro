---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = 'What Else Page';
---

<BaseLayout pageTitle={pageTitle}>
  <h2>What Else</h2>
  <hr />
  <div class="main-max-width container">
    <div class="form-wrapper">
      <h3>My Other Projects and Things</h3>
      <h3>In Progress</h3>
    </div>
  </div>
</BaseLayout>

<style>
  h2 {
    font-family: var(--serif);
    font-size: 2.5rem;
    font-weight: 200;
    margin-top: 2rem;
  }
  .container {
    margin: auto;
    margin-top: 4em;
  }

  h3 {
    text-align: center;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    font-weight: 400;
  }
</style>
