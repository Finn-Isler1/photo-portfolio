            <img src={getPhoto('Midas 2026 Launch-4')} alt="launch2" />
            <img src={getPhoto('Midas 2026 Launch-5')} alt="launch3" />
          </div>
          <div class="row">
            <img src={getPhoto('Midas 2026 Launch-2')} alt="launch1" />
            <img src={getPhoto('Midas 2026 Launch-6')} alt="launch2" />
            <img src={getPhoto('Midas 2026 Launch-10')} alt="launch3" />
          </div>
          <div class="row">
            <img src={getPhoto('Midas 2026 Launch')} alt="launch1" />
            <img src={getPhoto('Midas 2026 Launch-8')} alt="launch3" />
          </div>
