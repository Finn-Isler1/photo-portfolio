  </div>
</BaseLayout>

<style>
  /* Section nav */

  #home-page-nav {
    margin: 2rem 0 0 0;
  }

  #home-page-nav nav ul {
    display: flex;
    justify-content: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #home-page-nav nav ul li a {
    text-decoration: none;
    color: var(--primary-text-color);
    padding: 0.5rem 1.5rem;
    outline: 1px solid var(--primary-text-color);
  }

  /* MAIN PHOTO SECTION */

  #photo-projects {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
  }

  h2 {
    font-family: var(--serif);
    font-size: 2.5rem;
    font-weight: 200;
  }

  h3 {
    font-family: var(--sans);
    font-size: 1.5rem;
    font-weight: 200;
    display: flex;
    justify-content: left;
    margin: 2rem 0;
  }

  .gallery-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 2em;
  }

  .row {
    display: flex;
    gap: 20px;
  }

  img {
    flex: 1;
    min-width: 0;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .row {
      flex-direction: column;
      gap: 12px;
    }

    .gallery-wrapper {
      gap: 12px;
    }

    h2 {
      font-size: 1.8rem;
    }

    h3 {
      font-size: 1.2rem;
      margin: 1.2rem 0;
    }
  }
</style>
