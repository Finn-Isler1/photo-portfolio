        </div>
        <div class="row">
          <img src={getPhoto('life22')} />
          <img src={getPhoto('life17')} />
          <img src={getPhoto('life23')} />
        </div>
        <div class="row">
          <img src={getPhoto('life7')} />
          <img src={getPhoto('life9')} />
        </div>
        <div class="row">
