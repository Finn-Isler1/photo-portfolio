---
export interface Props {
  id: number;
  name: string;
  alt: string;
  videoPath: string;
  thumbnail: string;
  path: string;
}
const { id, name, alt, path, thumbnail } = Astro.props;
---

<div
  class="video-item"
  data-id={id}
  data-name={name}
  data-alt={alt}
  data-path={path}
  data-thumbnail={thumbnail}
>
  <a href={`./videos/${path}`}>
    <img src={`./videos/${thumbnail}`} alt={alt} loading="lazy" />
  </a>
</div>
