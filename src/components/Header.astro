---
const base = import.meta.env.BASE_URL;
---

<header>
  <div class="top">
    <div>
      <!-- <a href="#" class="fa fa-facebook"></a> -->
      <a
        href="https://www.instagram.com/finn_photog/"
        class="fa fa-instagram"
        target="_blank"></a>
    </div>
    <h1><a href={base}>Finn Isler</a></h1>
    <div></div>
  </div>

  <nav>
    <a href={base}>Home</a>
    <a href={`${base}video`}>Video</a>
    <a href={`${base}about`}>About</a>
    <a href={`${base}contact`}>Contact</a>
    <a href={`${base}what-else`}>What Else</a>
  </nav>
</header>

<style>
  header {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    margin: 2rem 0;
  }

  .top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    max-width: 1200px;
  }

  .top > div:first-child {
    text-align: left;
  }

  .top > div:last-child {
    text-align: right;
  }

  .top > h1 {
    text-align: center;
  }

  .fa {
    font-size: 1.5rem;
    margin: 0 0.5rem;
    transition: 0.2s ease;
    color: var(--background-color);
    background-color: black;
    padding: 0.25rem;
    border-radius: 50%;
  }

  h1 {
    color: var(--primary-text-color);
    margin-bottom: 1.5rem;
    font-size: 3rem;
  }

  nav {
    display: flex;
    gap: 100px;
    margin-top: 0.1rem;
    color: var(--secondary-text-color);
  }

  nav a {
    transition: 0.2s ease;
  }

  nav a:hover {
    color: var(--primary-text-color);
  }

  nav a:active {
    color: var(--primary-text-color);
  }

  .fa {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--primary-text-color);
    color: white;
    transition: 0.2s ease;
    font-size: 1.2rem;
  }

  .fa:hover {
    background-color: var(--primary-text-color);
  }
</style>
